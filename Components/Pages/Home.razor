@page "/"

@inject ExpenseApplicationService ExpenseApplicationService
@inject CategoryApplicationService CategoryApplicationService
@inject ExpenseDashboardService ExpenseDashboardService
@inject ExpenseService ExpenseService
@inject PresentationFormattingService PresentationFormattingService
@inject LocalizationService LocalizationService
@inject CategoryManagerUiState CategoryManagerUiState
@using FinanceProject.Services
@using FinanceProject.Configuration
@implements IAsyncDisposable

<PageTitle>Expense Manager</PageTitle>

<div class="page">
    <header class="hero">
        <div class="hero-content">
            <div>
                <h1>Expense Manager</h1>
                <p>Track your money with clarity, one month at a time.</p>
            </div>
            <div class="hero-actions">
                <button class="ghost" @onclick="ToggleCategoryManager">
                    @(CategoryManagerUiState.IsOpen ? LocalizationService.T("hide_categories") : LocalizationService.T("manage_categories"))
                </button>
                <div class="language-selector">
                    <label>
                        <span>@LocalizationService.T("language")</span>
                        <select @onchange="OnLanguageChanged">
                            <option value="@Language.Spanish" selected="@(LocalizationService.CurrentLanguage == Language.Spanish)">Español</option>
                            <option value="@Language.English" selected="@(LocalizationService.CurrentLanguage == Language.English)">English</option>
                        </select>
                    </label>
                </div>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert error">@ErrorMessage</div>
    }

    <section class="panel form-panel">
        <div class="grid form-grid">
            <label>
                <span>@LocalizationService.T("description")</span>
                <input @bind="PageState.NewExpense.Description" @bind:event="oninput" />
            </label>
            <label>
                <span>@LocalizationService.T("transaction_type")</span>
                <select @bind="PageState.NewExpenseTypeText">
                    @foreach (var transactionType in AppConfiguration.TransactionTypes)
                    {
                        <option value="@transactionType">@PresentationFormattingService.GetTransactionTypeLabel(transactionType)</option>
                    }
                </select>
            </label>
            <label>
                <span>@LocalizationService.T("date")</span>
                <InputDate @bind-Value="PageState.NewExpense.Date" />
            </label>
            <label>
                <span>@LocalizationService.T("category")</span>
                <select @bind="PageState.NewExpense.Category">
                    @foreach (var category in ManagedCategories)
                    {
                        <option value="@category">@PresentationFormattingService.GetCategoryLabel(category)</option>
                    }
                </select>
            </label>
            <label>
                <span>@LocalizationService.T("amount_eur")</span>
                <InputNumber @bind-Value="PageState.NewExpense.Amount" step="0.01" />
            </label>
            <div class="action-slot">
                <button class="primary" @onclick="AddExpenseAsync">@LocalizationService.T("add")</button>
            </div>
        </div>
    </section>

    <section class="panel toolbar">
        <label>
            <span>@LocalizationService.T("month")</span>
            <select @bind="SelectedMonthKey">
                @foreach (var month in AvailableMonths)
                {
                    <option value="@month.Key">@PresentationFormattingService.GetMonthLabel(month.Year, month.Month)</option>
                }
            </select>
        </label>
        <label>
            <span>@LocalizationService.T("category")</span>
            <select @bind="SelectedCategory">
                @foreach (var category in FilterCategories)
                {
                    <option value="@category">@PresentationFormattingService.GetCategoryLabel(category)</option>
                }
            </select>
        </label>
        <label>
            <span>@LocalizationService.T("sort")</span>
            <select @bind="SelectedSortOption">
                @foreach (var option in AppConfiguration.SortOptions)
                {
                    <option value="@option.Option">@PresentationFormattingService.GetSortOptionLabel(option.Option)</option>
                }
            </select>
        </label>
    </section>

    @if (CategoryManagerUiState.IsOpen)
    {
        <div class="category-modal-overlay" @onclick="CloseCategoryManager">
            <section class="panel category-manager category-manager-modal" @onclick:stopPropagation="true">
                <div class="category-manager-header">
                    <h3>@LocalizationService.T("manage_categories")</h3>
                    <button class="ghost" @onclick="CloseCategoryManager">@LocalizationService.T("close")</button>
                </div>

                <div class="category-manager-add">
                    <input
                        placeholder="@LocalizationService.T("category_name_placeholder")"
                        @bind="NewCategoryName"
                        @bind:event="oninput" />
                    <button class="primary" @onclick="AddCategoryAsync">@LocalizationService.T("add_category")</button>
                </div>

                <div class="category-manager-list">
                    @foreach (var category in ManagedCategories)
                    {
                        var isEditingCategory = string.Equals(EditingCategoryOriginal, category, StringComparison.OrdinalIgnoreCase);

                        <div class="category-manager-item">
                            @if (isEditingCategory)
                            {
                                <input class="row-input" @bind="EditingCategoryName" @bind:event="oninput" />
                                <div class="row-actions">
                                    <button class="ghost" @onclick="SaveCategoryEditAsync">@LocalizationService.T("save")</button>
                                    <button class="ghost danger" @onclick="CancelCategoryEdit">@LocalizationService.T("cancel")</button>
                                </div>
                            }
                            else
                            {
                                <span>@PresentationFormattingService.GetCategoryLabel(category)</span>
                                <div class="row-actions">
                                    <button class="ghost" @onclick="() => BeginCategoryEdit(category)">@LocalizationService.T("edit")</button>
                                    <button class="ghost danger" @onclick="() => DeleteCategoryAsync(category)">@LocalizationService.T("delete")</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </section>
        </div>
    }

    <footer class="summary-grid">
        <div class="summary-card">
            <span>@LocalizationService.T("month")</span>
            <strong>@SelectedMonthLabel</strong>
        </div>
        <div class="summary-card income">
            <span>@LocalizationService.T("income")</span>
            <strong>@CurrentSummary.TotalIncome.ToString("C2", CultureInfo.CurrentCulture)</strong>
        </div>
        <div class="summary-card expense">
            <span>@LocalizationService.T("expense")</span>
            <strong>@CurrentSummary.TotalExpenses.ToString("C2", CultureInfo.CurrentCulture)</strong>
        </div>
        <div class="summary-card balance">
            <span>@LocalizationService.T("balance")</span>
            <strong>@CurrentSummary.Balance.ToString("C2", CultureInfo.CurrentCulture)</strong>
        </div>
    </footer>

    <section class="content-grid">
        <div class="panel list-panel">
            <div class="list-header">
                <span>@LocalizationService.T("date")</span>
                <span>@LocalizationService.T("type")</span>
                <span>@LocalizationService.T("category")</span>
                <span>@LocalizationService.T("description")</span>
                <span>@LocalizationService.T("amount")</span>
                <span></span>
            </div>

            <div class="list-scroll">
                @if (VisibleExpenses.Count == 0)
                {
                    <div class="empty-state">@LocalizationService.T("no_transactions")</div>
                }
                else
                {
                    @foreach (var expense in VisibleExpenses)
                    {
                        var isEditing = PageState.EditingExpense?.Id == expense.Id;
                        <div class="list-row">
                            @if (isEditing)
                            {
                                <InputDate class="row-input" @bind-Value="PageState.EditingExpense!.Date" />
                                <select class="row-input" @bind="PageState.EditingExpenseTypeText">
                                    @foreach (var transactionType in AppConfiguration.TransactionTypes)
                                    {
                                        <option value="@transactionType">@PresentationFormattingService.GetTransactionTypeLabel(transactionType)</option>
                                    }
                                </select>
                                <select class="row-input" @bind="PageState.EditingExpense!.Category">
                                    @foreach (var category in ManagedCategories)
                                    {
                                        <option value="@category">@PresentationFormattingService.GetCategoryLabel(category)</option>
                                    }
                                </select>
                                <input class="row-input" @bind="PageState.EditingExpense!.Description" @bind:event="oninput" />
                                <InputNumber class="row-input" @bind-Value="PageState.EditingExpense!.Amount" step="0.01" />
                                <div class="row-actions">
                                    <button class="ghost" @onclick="SaveEditAsync">@LocalizationService.T("save")</button>
                                    <button class="ghost danger" @onclick="CancelEdit">@LocalizationService.T("cancel")</button>
                                </div>
                            }
                            else
                            {
                                <span>@expense.Date.ToString("dd/MM/yyyy")</span>
                                <span class="type-pill @(expense.TransactionType == TransactionType.Income ? "income" : "expense")">@PresentationFormattingService.GetTransactionTypeLabel(expense.TransactionType)</span>
                                <span>@PresentationFormattingService.GetCategoryLabel(expense.Category)</span>
                                <span>@expense.Description</span>
                                <span>@expense.Amount.ToString("C2", CultureInfo.CurrentCulture)</span>
                                <div class="row-actions">
                                    <button class="ghost" @onclick="() => BeginEdit(expense)">@LocalizationService.T("edit")</button>
                                    <button class="ghost danger" @onclick="() => DeleteExpenseAsync(expense.Id)">@LocalizationService.T("delete")</button>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="charts-column">
            <div class="panel chart-panel">
                <div class="chart-header">
                    <h2>@LocalizationService.T("expense_distribution")</h2>
                    <span>@SelectedMonthLabel</span>
                </div>
                @if (CategoryChartItems.Count == 0)
                {
                    <div class="empty-state">@LocalizationService.T("no_expense_data")</div>
                }
                else
                {
                    <div class="donut-layout">
                        <div class="donut" style="@GetDonutStyle()">
                            <div class="donut-hole">
                                <strong>@CurrentSummary.TotalExpenses.ToString("C0", CultureInfo.CurrentCulture)</strong>
                                <span>@LocalizationService.T("expenses_total")</span>
                            </div>
                        </div>
                        <div class="legend">
                            @foreach (var item in CategoryChartItems)
                            {
                                <div class="legend-item">
                                    <span class="legend-color" style="background:@item.Color"></span>
                                    <span>@PresentationFormattingService.GetCategoryLabel(item.Category)</span>
                                    <strong>@item.Total.ToString("C2", CultureInfo.CurrentCulture)</strong>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="panel chart-panel">
                <div class="chart-header">
                    <h2>@LocalizationService.T("income_vs_expenses")</h2>
                    <span>@SelectedMonthLabel</span>
                </div>
                <div class="bar-chart">
                    <div class="bar-group">
                        <div class="bar-area">
                            <div class="bar income" style="height:@GetBarHeight(CurrentSummary.TotalIncome)"></div>
                        </div>
                        <span>@LocalizationService.T("income")</span>
                        <strong>@CurrentSummary.TotalIncome.ToString("C2", CultureInfo.CurrentCulture)</strong>
                    </div>
                    <div class="bar-group">
                        <div class="bar-area">
                            <div class="bar expense" style="height:@GetBarHeight(CurrentSummary.TotalExpenses)"></div>
                        </div>
                        <span>@LocalizationService.T("expense")</span>
                        <strong>@CurrentSummary.TotalExpenses.ToString("C2", CultureInfo.CurrentCulture)</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

@code {
    private static readonly string[] ChartColors =
    [
        "#ff5722",
        "#e91e63",
        "#3f51b5",
        "#009688",
        "#9c27b0",
        "#f44336",
        "#4caf50",
        "#ff9800",
        "#2196f3",
        "#8bc34a"
    ];

    private readonly HomePageState PageState = new();
    private List<Expense> AllExpenses { get; set; } = [];
    private List<string> ManagedCategories { get; set; } = [];
    private string SelectedCategory { get; set; } = AppConfiguration.AllCategoriesLabel;
    private ExpenseSortOption SelectedSortOption { get; set; } = AppConfiguration.DefaultSortOption;
    private string _selectedMonthKey = string.Empty;
    private string NewCategoryName { get; set; } = string.Empty;
    private string? EditingCategoryOriginal { get; set; }
    private string EditingCategoryName { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }

    private List<string> FilterCategories =>
    [
        AppConfiguration.AllCategoriesLabel,
        ..ManagedCategories
    ];

    private string SelectedMonthKey
    {
        get => _selectedMonthKey;
        set
        {
            if (_selectedMonthKey == value)
            {
                return;
            }

            _selectedMonthKey = value;
            PageState.AlignNewExpenseDate(BuildDateInSelectedMonth(PageState.NewExpense.Date.Day));
            ErrorMessage = null;
        }
    }

    private List<MonthViewModel> AvailableMonths => ExpenseDashboardService
        .GetAvailableMonths(AllExpenses, DateTime.Today)
        .Select(month => new MonthViewModel(month.Year, month.Month))
        .ToList();

    private List<Expense> VisibleExpenses => ExpenseDashboardService.GetVisibleExpenses(
        AllExpenses,
        SelectedMonthOption,
        SelectedCategory,
        SelectedSortOption);

    private MonthlySummary CurrentSummary => ExpenseDashboardService.GetSummary(AllExpenses, SelectedMonthOption);

    private List<CategoryChartItem> CategoryChartItems => BuildCategoryChartItems();

    private MonthOption? SelectedMonthOption => TryParseMonth(SelectedMonthKey);
    private string SelectedMonthLabel => SelectedMonthOption is { } month
        ? PresentationFormattingService.GetMonthLabel(month.Year, month.Month)
        : CurrentSummary.MonthName;

    protected override async Task OnInitializedAsync()
    {
        await LocalizationService.InitializeAsync();
        LocalizationService.OnLanguageChanged += StateHasChanged;
        CategoryManagerUiState.OnChange += StateHasChanged;
        ReloadExpenses();
    }

    private void ReloadExpenses(DateTime? preferredMonth = null)
    {
        LoadCategories();
        AllExpenses = ExpenseApplicationService.GetAllExpenses();
        EnsureSelectedMonth(preferredMonth);
        PageState.ResetNewExpense(BuildDateInSelectedMonth(DateTime.Today.Day));

        if (!ManagedCategories.Contains(PageState.NewExpense.Category, StringComparer.OrdinalIgnoreCase))
        {
            PageState.NewExpense.Category = ResolveDefaultCategory();
        }

        if (SelectedCategory != AppConfiguration.AllCategoriesLabel
            && !ManagedCategories.Contains(SelectedCategory, StringComparer.OrdinalIgnoreCase))
        {
            SelectedCategory = AppConfiguration.AllCategoriesLabel;
        }

        if (PageState.EditingExpense is not null
            && !ManagedCategories.Contains(PageState.EditingExpense.Category, StringComparer.OrdinalIgnoreCase))
        {
            PageState.EditingExpense.Category = ResolveDefaultCategory();
        }

        ErrorMessage = null;
    }

    private void LoadCategories()
    {
        ManagedCategories = CategoryApplicationService.GetAllCategories();
        if (ManagedCategories.Count == 0)
        {
            ManagedCategories = AppConfiguration.Categories.ToList();
        }
    }

    private string ResolveDefaultCategory()
    {
        var defaultCategory = ManagedCategories.FirstOrDefault(category =>
            string.Equals(category, AppConfiguration.DefaultCategory, StringComparison.OrdinalIgnoreCase));

        return defaultCategory
            ?? ManagedCategories.FirstOrDefault()
            ?? AppConfiguration.DefaultCategory;
    }

    private async Task AddCategoryAsync()
    {
        if (!CategoryApplicationService.AddCategory(NewCategoryName, out var errorKey))
        {
            SetCategoryError(errorKey);
            return;
        }

        NewCategoryName = string.Empty;
        ReloadExpenses();
        await InvokeAsync(StateHasChanged);
    }

    private void CloseCategoryManager()
    {
        CancelCategoryEdit();
        NewCategoryName = string.Empty;
        CategoryManagerUiState.Close();
    }

    private void BeginCategoryEdit(string category)
    {
        EditingCategoryOriginal = category;
        EditingCategoryName = category;
        ErrorMessage = null;
    }

    private void CancelCategoryEdit()
    {
        EditingCategoryOriginal = null;
        EditingCategoryName = string.Empty;
    }

    private async Task SaveCategoryEditAsync()
    {
        if (string.IsNullOrWhiteSpace(EditingCategoryOriginal))
        {
            return;
        }

        if (!CategoryApplicationService.RenameCategory(EditingCategoryOriginal, EditingCategoryName, out var errorKey))
        {
            SetCategoryError(errorKey);
            return;
        }

        CancelCategoryEdit();
        ReloadExpenses();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteCategoryAsync(string category)
    {
        if (!CategoryApplicationService.DeleteCategory(category, out var errorKey))
        {
            SetCategoryError(errorKey);
            return;
        }

        if (string.Equals(EditingCategoryOriginal, category, StringComparison.OrdinalIgnoreCase))
        {
            CancelCategoryEdit();
        }

        ReloadExpenses();
        await InvokeAsync(StateHasChanged);
    }

    private void SetCategoryError(string? errorKey)
    {
        ErrorMessage = string.IsNullOrWhiteSpace(errorKey)
            ? LocalizationService.T("category_error_generic")
            : LocalizationService.T(errorKey);
    }

    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<Language>(e.Value?.ToString(), out var language))
        {
            await LocalizationService.SetLanguageAsync(language);
            StateHasChanged();
        }
    }

    private void ToggleCategoryManager()
    {
        CategoryManagerUiState.Toggle();
    }

    private async Task AddExpenseAsync()
    {
        var expense = PageState.BuildNewExpense(ParseTransactionType);

        if (!ExpenseService.ValidateExpense(expense, out var errorMessage))
        {
            ErrorMessage = errorMessage;
            return;
        }

        ExpenseApplicationService.AddExpense(expense);
        PageState.ResetNewExpense(BuildDateInSelectedMonth(DateTime.Today.Day));
        ReloadExpenses(expense.Date);
        await InvokeAsync(StateHasChanged);
    }

    private void BeginEdit(Expense expense)
    {
        PageState.BeginEdit(expense);
        ErrorMessage = null;
    }

    private async Task SaveEditAsync()
    {
        var expenseToPersist = PageState.BuildEditedExpense(ParseTransactionType);
        if (expenseToPersist is null)
        {
            return;
        }

        if (!ExpenseService.ValidateExpense(expenseToPersist, out var errorMessage))
        {
            ErrorMessage = errorMessage;
            return;
        }

        if (!ExpenseApplicationService.UpdateExpense(expenseToPersist))
        {
            ErrorMessage = "The transaction no longer exists.";
            return;
        }

        PageState.CancelEdit();
        ReloadExpenses(expenseToPersist.Date);
        await InvokeAsync(StateHasChanged);
    }

    private void CancelEdit()
    {
        PageState.CancelEdit();
        ErrorMessage = null;
    }

    private async Task DeleteExpenseAsync(string expenseId)
    {
        if (!ExpenseApplicationService.DeleteExpense(expenseId))
        {
            return;
        }

        PageState.CancelEdit();
        ReloadExpenses();
        await InvokeAsync(StateHasChanged);
    }

    private void EnsureSelectedMonth(DateTime? preferredMonth = null)
    {
        var months = ExpenseDashboardService.GetAvailableMonths(AllExpenses, DateTime.Today);
        SelectedMonthKey = ExpenseDashboardService.ResolveSelectedMonthKey(months, SelectedMonthKey, preferredMonth);
    }

    private List<CategoryChartItem> BuildCategoryChartItems()
    {
        var totals = ExpenseDashboardService
            .GetExpenseCategoryTotals(VisibleExpenses)
            .Select((item, index) => new CategoryChartItem(
                item.Category,
                item.Total,
                ChartColors[index % ChartColors.Length]))
            .OrderByDescending(item => item.Total)
            .ToList();

        return totals;
    }

    private string GetDonutStyle()
    {
        if (CategoryChartItems.Count == 0)
        {
            return "background:conic-gradient(#d7dce6 0deg 360deg);";
        }

        var grandTotal = CategoryChartItems.Sum(item => item.Total);
        decimal currentPercentage = 0;
        var segments = new List<string>();

        foreach (var item in CategoryChartItems)
        {
            var sweep = grandTotal == 0 ? 0 : item.Total / grandTotal * 100m;
            var nextPercentage = currentPercentage + sweep;
            segments.Add($"{item.Color} {currentPercentage:F2}% {nextPercentage:F2}%");
            currentPercentage = nextPercentage;
        }

        return $"background:conic-gradient({string.Join(", ", segments)});";
    }

    private string GetBarHeight(decimal value)
    {
        var max = Math.Max(CurrentSummary.TotalIncome, CurrentSummary.TotalExpenses);
        if (max <= 0)
        {
            return "8%";
        }

        var percentage = Math.Max(8m, decimal.Round(value / max * 100m, 2));
        return $"{percentage.ToString(CultureInfo.InvariantCulture)}%";
    }

    private DateTime BuildDateInSelectedMonth(int day)
    {
        var targetMonth = SelectedMonthOption ?? new MonthOption(DateTime.Today.Year, DateTime.Today.Month);
        var safeDay = Math.Min(day, DateTime.DaysInMonth(targetMonth.Year, targetMonth.Month));
        return new DateTime(targetMonth.Year, targetMonth.Month, safeDay);
    }

    private static string BuildMonthKey(int year, int month) => $"{year:D4}-{month:D2}";

    private static MonthOption? TryParseMonth(string monthKey)
    {
        if (string.IsNullOrWhiteSpace(monthKey))
        {
            return null;
        }

        var parts = monthKey.Split('-');
        if (parts.Length != 2
            || !int.TryParse(parts[0], out var year)
            || !int.TryParse(parts[1], out var month))
        {
            return null;
        }

        return new MonthOption(year, month);
    }

    private static TransactionType ParseTransactionType(string value)
    {
        return Enum.TryParse<TransactionType>(value, out var result)
            ? result
            : TransactionType.Expense;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        LocalizationService.OnLanguageChanged -= StateHasChanged;
        CategoryManagerUiState.OnChange -= StateHasChanged;
        await Task.CompletedTask;
    }

    private sealed record MonthViewModel(int Year, int Month)
    {
        public string Key => BuildMonthKey(Year, Month);
        public string DisplayName => new DateTime(Year, Month, 1).ToString("MMMM yyyy");
    }

    private sealed record CategoryChartItem(string Category, decimal Total, string Color);
}