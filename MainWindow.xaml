<Window x:Class="FinanceProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinanceProject"
        xmlns:converters="clr-namespace:FinanceProject.Converters"
        xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
        mc:Ignorable="d"
    Title="Expense Manager" Height="850" Width="1600"
    WindowState="Maximized" Background="#F5F7FA"
    UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
            <converters:TransactionTypeToColorConverter x:Key="TransactionTypeToColorConverter"/>
        
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        
        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        
        <!-- Estilos personalizados -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#27632A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E4620"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
    <Grid Width="1600" Height="850">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1A237E" Padding="30,20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="💰 Expense Manager" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                <TextBlock Text="Gestiona tus gastos de forma sencilla" FontSize="14" Foreground="#B3E5FC"/>
            </StackPanel>
        </Border>
        
        <!-- Input Section -->
        <Border Grid.Row="1" Background="White" Padding="30,25" BorderThickness="0,1" BorderBrush="#E0E0E0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Descripción" FontSize="12" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBox x:Name="DescriptionTextBox" Style="{StaticResource TextBoxStyle}" Height="40"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Tipo" FontSize="12" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,5"/>
                    <ComboBox x:Name="TransactionTypeComboBox" Style="{StaticResource ComboBoxStyle}" Height="40" SelectedValuePath="Content">
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Gasto</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Ingreso</System:String>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Fecha" FontSize="12" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DatePicker" Style="{StaticResource DatePickerStyle}" Height="40" VerticalContentAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Categoría" FontSize="12" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CategoryComboBox" Style="{StaticResource ComboBoxStyle}" Height="40">
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Compra</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Alquiler</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Restaurante</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Gasolina</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Préstamos</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Servicios</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Entretenimiento</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Otros</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Ingresos</System:String>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Grid.Column="4" Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Cantidad (€)" FontSize="12" FontWeight="SemiBold" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBox x:Name="AmountTextBox" Style="{StaticResource TextBoxStyle}" Height="40"/>
                </StackPanel>
                
                <Button Grid.Column="5" Content="➕ Agregar" Click="AddExpenseButton_Click" 
                        Style="{StaticResource ButtonStyle}" VerticalAlignment="Bottom" Height="40"/>
            </Grid>
        </Border>
        
        <!-- List Section -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Filter and Sort Section -->
            <Border Grid.Row="0" Background="White" Padding="20,15" BorderThickness="0,1" BorderBrush="#E0E0E0" Margin="20,10,20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filtrar por categoría:" FontSize="12" FontWeight="SemiBold" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="FilterComboBox" Style="{StaticResource ComboBoxStyle}" Width="180" Height="35" SelectionChanged="FilterComboBox_SelectionChanged" Margin="0,0,30,0">
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Todas</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Compra</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Alquiler</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Restaurante</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Gasolina</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Préstamos</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Servicios</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Entretenimiento</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Otros</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Ingresos</System:String>
                    </ComboBox>
                    
                    <TextBlock Text="Ordenar por:" FontSize="12" FontWeight="SemiBold" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="SortComboBox" Style="{StaticResource ComboBoxStyle}" Width="200" Height="35" SelectionChanged="SortComboBox_SelectionChanged">
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Fecha Descendente</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Fecha Ascendente</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Cantidad Descendente</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Cantidad Ascendente</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Categoría A-Z</System:String>
                    </ComboBox>
                </StackPanel>
            </Border>
            
            <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header Row -->
                        <Border Grid.Row="0" Background="#F5F7FA" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="0">
                            <Grid Height="45">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="Date" FontSize="12" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBlock Grid.Column="1" Text="Type" FontSize="12" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBlock Grid.Column="2" Text="Category" FontSize="12" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBlock Grid.Column="3" Text="Description" FontSize="12" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBlock Grid.Column="4" Text="Amount (EUR)" FontSize="12" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center" Margin="10,0"/>
                                <TextBlock Grid.Column="5" Text="✏" FontSize="12" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                                <TextBlock Grid.Column="6" Text="🗑" FontSize="12" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                            </Grid>
                        </Border>
                        
                        <!-- List Items -->
                        <ListBox Grid.Row="1" x:Name="ExpensesListView" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50" Margin="10,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="35"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Modo Vista -->
                                    <!-- View mode -->
                                    <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat=dd/MM/yyyy}" VerticalAlignment="Center" FontSize="13" Foreground="#333333" Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolConverter}, ConverterParameter=BoolToVis}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TransactionType}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Category}" VerticalAlignment="Center" FontSize="13" Foreground="#333333" Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolConverter}, ConverterParameter=BoolToVis}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Description}" VerticalAlignment="Center" FontSize="13" Foreground="#333333" Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolConverter}, ConverterParameter=BoolToVis}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Amount, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="13" Foreground="#333333" Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolConverter}, ConverterParameter=BoolToVis}"/>
                                    
                                    <!-- Modo Edición -->
                                    <!-- Edit mode -->
                                    <TextBox Grid.Column="0" Text="{Binding Date, StringFormat=dd/MM/yyyy}" Padding="5" VerticalAlignment="Center" FontSize="12" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <ComboBox Grid.Column="2" SelectedItem="{Binding Category}" Padding="5" FontSize="12"
                                              Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center"
                                              ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <TextBox Grid.Column="3" Text="{Binding Description}" Padding="5" VerticalAlignment="Center" FontSize="12" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBox Grid.Column="4" Text="{Binding Amount}" Padding="5" VerticalAlignment="Center" FontSize="12" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    
                                    <!-- Botones -->
                                        <!-- Action buttons -->
                                        <Button Grid.Column="5" Content="✏️" Background="Transparent" BorderThickness="0" FontSize="14" 
                                            Click="EditButton_Click" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5" Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolConverter}, ConverterParameter=BoolToVis}"/>
                                        <Button Grid.Column="6" Content="🗑️" Background="Transparent" BorderThickness="0" FontSize="14" 
                                            Click="DeleteButton_Click" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5" Visibility="{Binding IsEditing, Converter={StaticResource InvertBoolConverter}, ConverterParameter=BoolToVis}"/>
                                    
                                    <!-- Botones Guardar/Cancelar en edición -->
                                        <!-- Save/Cancel buttons in edit mode -->
                                        <Button Grid.Column="5" Content="✅" Background="Transparent" BorderThickness="0" FontSize="14" 
                                            Click="SaveButton_Click" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <Button Grid.Column="6" Content="❌" Background="Transparent" BorderThickness="0" FontSize="14" 
                                            Click="CancelButton_Click" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F7FA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    </Grid>
                    
                    <!-- Right column: Charts -->
                    <Border Grid.Column="1" Background="#FAFAFA" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Margin="10,0,0,0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Pie Chart -->
                            <oxy:PlotView Grid.Column="0" Model="{Binding ChartModel}" Background="Transparent" Margin="0,0,5,0"/>
                            
                            <!-- Bar Chart -->
                            <oxy:PlotView Grid.Column="1" Model="{Binding IncomeExpenseChartModel}" Background="Transparent" Margin="5,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Summary Footer -->
            <Border Grid.Row="2" Background="#1A237E" Padding="20" CornerRadius="8" Margin="20,0,20,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="{Binding MonthlySummary.MonthName, StringFormat='Resumen de {0}:'}" FontSize="14" FontWeight="SemiBold" 
                               Foreground="White" VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="30,0" VerticalAlignment="Center">
                        <TextBlock Text="Ingresos: " FontSize="13" Foreground="White" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding MonthlySummary.TotalIncome, StringFormat=N2}" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#90EE90" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,30,0" VerticalAlignment="Center">
                        <TextBlock Text="Gastos: " FontSize="13" Foreground="White" Margin="0,0,5,0"/>
                        <TextBlock x:Name="TotalTextBlock" Text="0,00" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#FF7F7F" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Balance: " FontSize="13" Foreground="White" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding MonthlySummary.Balance, StringFormat=N2}" FontSize="16" FontWeight="Bold" 
                                   Foreground="#4FD1C7" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Viewbox>
</Window>