<Window x:Class="FinanceProject.EditExpenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Transaction" Height="520" Width="560" MinHeight="420" MinWidth="420"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA" ResizeMode="CanResize">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Description -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Description" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <TextBox x:Name="DescriptionTextBox" Padding="10,8" FontSize="14" Background="White" BorderThickness="0"/>
            </Border>
        </StackPanel>
        
        <!-- Date -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Date" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <DatePicker x:Name="DatePicker" Padding="10,8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0"/>
        </StackPanel>
        
        <!-- Category -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Category" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <ComboBox x:Name="CategoryComboBox" Padding="10,8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0"/>
        </StackPanel>
        
        <!-- Amount -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Amount (EUR)" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <TextBox x:Name="AmountTextBox" Padding="10,8" FontSize="14" Background="White" BorderThickness="0"/>
            </Border>
        </StackPanel>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Width="100" Height="40" 
                    Background="#E0E0E0" Foreground="#333333" FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,10,0"/>
            <Button Content="Save" Click="Save_Click" Width="100" Height="40" 
                    Background="#2E7D32" Foreground="White" FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
