<Window x:Class="FinanceProject.EditExpenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Gasto" Height="520" Width="560" MinHeight="420" MinWidth="420"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA" ResizeMode="CanResize">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Descripción -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Descripción" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <TextBox x:Name="DescriptionTextBox" Padding="10,8" FontSize="14" Background="White" BorderThickness="0"/>
            </Border>
        </StackPanel>
        
        <!-- Fecha -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Fecha" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <DatePicker x:Name="DatePicker" Padding="10,8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0"/>
        </StackPanel>
        
        <!-- Categoría -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Categoría" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <ComboBox x:Name="CategoryComboBox" Padding="10,8" FontSize="14" BorderThickness="1" BorderBrush="#E0E0E0">
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Compra</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Alquiler</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Restaurante</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Gasolina</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Préstamos</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Servicios</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Entretenimiento</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=netstandard">Otros</System:String>
            </ComboBox>
        </StackPanel>
        
        <!-- Cantidad -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Cantidad (€)" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <TextBox x:Name="AmountTextBox" Padding="10,8" FontSize="14" Background="White" BorderThickness="0"/>
            </Border>
        </StackPanel>
        
        <!-- Botones -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Click="Cancel_Click" Width="100" Height="40" 
                    Background="#E0E0E0" Foreground="#333333" FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand" Margin="0,0,10,0"/>
            <Button Content="Guardar" Click="Save_Click" Width="100" Height="40" 
                    Background="#2E7D32" Foreground="White" FontSize="14" FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
